{
  "name": "libalpm",
  "version": "0.2.0",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/assapir/alpm-node"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "napi build --platform --release --esm",
    "build:debug": "napi build --platform --esm",
    "artifacts": "napi artifacts --npm-dir npm",
    "typecheck": "tsgo",
    "test": "node --test __test__/*.spec.ts"
  },
  "napi": {
    "binaryName": "alpm",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "armv7-unknown-linux-gnueabihf"
    ]
  },
  "optionalDependencies": {
    "libalpm-linux-x64-gnu": "0.2.0",
    "libalpm-linux-arm64-gnu": "0.2.0",
    "libalpm-linux-arm-gnueabihf": "0.2.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "latest"
  },
  "packageManager": "pnpm@10.33.0"
}
